<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Fix: power cables render on top of power switch -->
	<!-- Raise PowerSwitch altitudeLayer from Building to BuildingOnTop -->
	<!-- so it always renders above conduit linked graphics -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="PowerSwitch"]/altitudeLayer</xpath>
		<value>
			<altitudeLayer>BuildingOnTop</altitudeLayer>
		</value>
	</Operation>

</Patch>
